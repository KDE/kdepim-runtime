msgstr "Jotakin meni vikaan"

#. i18n: ectx: label, entry (BaseUrl), group (General)
#: etesyncresource.kcfg:14
#, kde-format
msgid "Server URL"
msgstr "Palvelimen verkko-osoite"

#. i18n: ectx: tooltip, entry (BaseUrl), group (General)
#. i18n: ectx: whatsthis, entry (BaseUrl), group (General)
#: etesyncresource.kcfg:15 etesyncresource.kcfg:16
#, kde-format
msgid ""
"The URL of the EteSync server, should be something like https://myserver.org/"
msgstr ""
"EteSync-palvelimen verkko-osoite, jonka tulisi olla muotoa https://"
"omapalvelin.fi/"

#. i18n: ectx: label, entry (Username), group (General)
#: etesyncresource.kcfg:19
#, kde-format
msgctxt "the username to login on server"
msgid "Username"
msgstr "Käyttäjätunnus"

#. i18n: ectx: tooltip, entry (Username), group (General)
#. i18n: ectx: whatsthis, entry (Username), group (General)
#: etesyncresource.kcfg:20 etesyncresource.kcfg:21
#, kde-format
msgid "The username that is used to log into the EteSync server"
msgstr "EteSync-palvelimeen kirjauduttaessa käytettävä käyttäjätunnus"

#. i18n: ectx: label, entry (BasePath), group (General)
#: etesyncresource.kcfg:24
#, kde-format
msgid "Path to base directory"
msgstr "Peruskansion polku"

#: setupwizard.cpp:28
#, kde-format
msgctxt "@title:window"
msgid "EteSync configuration wizard"
msgstr "Opastettu EteSync-asetus"

#: setupwizard.cpp:66
#, kde-format
msgid "Login Credentials"
msgstr "Todennustiedot"

#: setupwizard.cpp:67
#, kde-format
msgid "Enter your credentials to login to the EteSync server"
msgstr "Anna todennustiedot EteSync-palvelimeen kirjautumiseksi"

#: setupwizard.cpp:76
#, kde-format
msgid "Username:"
msgstr "Käyttäjätunnus:"

#: setupwizard.cpp:82
#, kde-format
msgid "Password:"
msgstr "Salasana:"

#: setupwizard.cpp:85
#, kde-format
msgctxt "@option:check"
msgid "Advanced settings"
msgstr "Lisäasetukset"

#: setupwizard.cpp:90
#, kde-format
msgid "Server:"
msgstr "Palvelin:"

#: setupwizard.cpp:103
#, kde-format
msgid ""
"🛈 The password field is empty because EteSync does not store it for security "
"reasons."
msgstr ""
"🛈 Salasanakenttä on tyhjä, koska EteSync ei turvallisuussyistä tallenna "
"salasanaa."

#: setupwizard.cpp:135
#, kde-format
msgid ""
"Please ensure that the server URL is correct. The URL should start with "
"http:// or https://."
msgstr ""
"Varmista, että palvelimen verkko-osoite on oikein. Sen tulisi alkaa http:// "
"tai https://."

#: setupwizard.cpp:137
#, kde-format
msgid ""
"Could not connect to the server. Please ensure that the server URL is "
"correct."
msgstr ""
"Palvelimeen ei saada yhteyttä. Varmista, että palvelimen verkko-osoite on "
"oikein."

#: setupwizard.cpp:139
#, kde-format
msgid "EteSync server not found. Please ensure that the server URL is correct."
msgstr ""
"EteSync-palvelinta ei löytynyt. Varmista, että palvelimen verkko-osoite on "
"oikein."

msgstr "Palvelinvirhe"

#: etesyncresource.cpp:204
#, kde-format
msgid ""
"Your EteSync credentials were changed. Please click OK to re-enter your "
"credentials."
msgstr ""
"EteSync-todennustietosi ovat muuttuneet. Syötä ne uudelleen napsauttamalla "
"OK."

#: etesyncresource.cpp:206
#, kde-format
msgid "Credentials Changed"
msgstr "Todennustiedot ovat muuttuneet"

#: etesyncresource.cpp:207
#, kde-format
msgid "Your EteSync credentials were changed or are missing."
msgstr "EteSync-todennustiedot ovat muuttuneet tai puuttuvat."

#: etesyncresource.cpp:257
#, kde-format
msgid "Cannot retrieve items - account is null"
msgstr "Tietueita ei voi noutaa: tili on tyhjä"


#: setupwizard.cpp:28
#, kde-format
msgctxt "@title:window"
msgid "EteSync configuration wizard"
msgstr "Průvodce nastavením EteSync"

#: setupwizard.cpp:66
#, kde-format
msgid "Login Credentials"
msgstr "Přihlašovací údaje"

#: setupwizard.cpp:67
#, kde-format
msgid "Enter your credentials to login to the EteSync server"
msgstr "Zadejte své přihlašovací údaje pro přihlášení k serveru EteSync"

#: setupwizard.cpp:76
#, kde-format
msgid "Username:"
msgstr "Uživatelské jméno:"

#: setupwizard.cpp:82
#, kde-format
msgid "Password:"
msgstr "Heslo:"

#: setupwizard.cpp:85
#, kde-format
msgctxt "@option:check"
msgid "Advanced settings"
msgstr "Pokročilá nastavení"

#: setupwizard.cpp:90
#, kde-format
msgid "Server:"
msgstr "Server:"

#: setupwizard.cpp:103
#, kde-format
msgid ""
"🛈 The password field is empty because EteSync does not store it for security "
"reasons."
msgstr ""
"🛈 Pole pro heslo je prázdné, protože EteSync jej z bezpečnostních důvodů "
"neukládá."

#: setupwizard.cpp:135
#, kde-format
msgid ""
"Please ensure that the server URL is correct. The URL should start with "
"http:// or https://."
msgstr ""
"Zkontrolujte, zda je adresa URL serveru správná. Adresa URL by měla začínat "
"http:// nebo https://."

#: setupwizard.cpp:137
#, kde-format
msgid ""
"Could not connect to the server. Please ensure that the server URL is "
"correct."
msgstr ""
"Nelze se připojit k serveru. Zkontrolujte, zda je adresa URL serveru správná."

#: setupwizard.cpp:139
#, kde-format
msgid "EteSync server not found. Please ensure that the server URL is correct."
msgstr ""
"Server EteSync nebyl nalezen. Zkontrolujte, zda je adresa URL serveru "
"správná."

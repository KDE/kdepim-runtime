#. i18n: ectx: label, entry (BaseUrl), group (General)
#: etesyncresource.kcfg:14
#, kde-format
msgid "Server URL"
msgstr "URL du serveur"

#. i18n: ectx: tooltip, entry (BaseUrl), group (General)
#. i18n: ectx: whatsthis, entry (BaseUrl), group (General)
#: etesyncresource.kcfg:15 etesyncresource.kcfg:16
#, kde-format
msgid ""
"The URL of the EteSync server, should be something like https://myserver.org/"
msgstr ""
"L'URL du serveur « EteSync » doit être de la forme « https://monserveur.org »"

#. i18n: ectx: label, entry (Username), group (General)
#: etesyncresource.kcfg:19
#, kde-format
msgctxt "the username to login on server"
msgid "Username"
msgstr "Nom d'utilisateur"

#. i18n: ectx: tooltip, entry (Username), group (General)
#. i18n: ectx: whatsthis, entry (Username), group (General)
#: etesyncresource.kcfg:20 etesyncresource.kcfg:21
#, kde-format
msgid "The username that is used to log into the EteSync server"
msgstr ""
"Le nom d'utilisateur employé pour une connexion à un serveur « EteSync »"

#. i18n: ectx: label, entry (BasePath), group (General)
#: etesyncresource.kcfg:24
#, kde-format
msgid "Path to base directory"
msgstr "Emplacement vers le dossier de référence"

#: setupwizard.cpp:28
#, kde-format
msgctxt "@title:window"
msgid "EteSync configuration wizard"
msgstr "Assistant de configuration pour EteSync"

#: setupwizard.cpp:66
#, kde-format
msgid "Login Credentials"
msgstr "Identifiants de connexion"

#: setupwizard.cpp:67
#, kde-format
msgid "Enter your credentials to login to the EteSync server"
msgstr "Saisir vos identifiants pour une connexion à un serveur « EteSync »"

#: setupwizard.cpp:76
#, kde-format
msgid "Username:"
msgstr "Nom d'utilisateur :"

#: setupwizard.cpp:82
#, kde-format
msgid "Password:"
msgstr "Mot de passe :"

#: setupwizard.cpp:85
#, kde-format
msgctxt "@option:check"
msgid "Advanced settings"
msgstr "Configuration avancée"

#: setupwizard.cpp:90
#, kde-format
msgid "Server:"
msgstr "Serveur :"

#: setupwizard.cpp:103
#, kde-format
msgid ""
"🛈 The password field is empty because EteSync does not store it for security "
"reasons."
msgstr ""
"🛈 Le champ de mot de passe est vide car EteSync ne l'enregistre pas pour des "
"raisons de sécurité."

#: setupwizard.cpp:135
#, kde-format
msgid ""
"Please ensure that the server URL is correct. The URL should start with "
"http:// or https://."
msgstr ""
"Veuillez vous assurer que l'URL du serveur est correct. Elle doit commencer "
"par « http://  » ou « https:// »."

#: setupwizard.cpp:137
#, kde-format
msgid ""
"Could not connect to the server. Please ensure that the server URL is "
"correct."
msgstr ""
"Impossible de se connecter au serveur. Veuillez vous assurer que l'URL du "
"serveur est correct."

#: setupwizard.cpp:139
#, kde-format
msgid "EteSync server not found. Please ensure that the server URL is correct."
msgstr ""
"Impossible de localiser le serveur « EteSync ». Veuillez vous assurer que "
"l'URL du serveur est correct."


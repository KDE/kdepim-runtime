#: etesyncresource.cpp:206
#, kde-format
msgid ""
"Your EteSync credentials were changed. Please click OK to re-enter your "
"credentials."
msgstr ""
"Vaše prihlasovacie údaje EteSync boli zmenené. Kliknutím na OK ich zadáte "
"znova."

#: etesyncresource.cpp:208
#, kde-format
msgid "Credentials Changed"
msgstr "Prihlasovacie údaje zmenené"

#: etesyncresource.cpp:209
#, kde-format
msgid "Your EteSync credentials were changed or are missing."
msgstr "Vaše prihlasovacie údaje EteSync boli zmenené alebo chýbajú."

#: etesyncresource.cpp:259
#, kde-format
msgid "Cannot retrieve items - account is null"
msgstr "Nie je možné získať položky – účet je prázdny"


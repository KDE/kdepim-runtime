#. i18n: ectx: tooltip, entry (Username), group (General)
#. i18n: ectx: whatsthis, entry (Username), group (General)
#: etesyncresource.kcfg:20 etesyncresource.kcfg:21
#, kde-format
msgid "The username that is used to log into the EteSync server"
msgstr "Používateľské meno, ktoré sa používa na prihlásenie na server EteSync"

#. i18n: ectx: label, entry (BasePath), group (General)
#: etesyncresource.kcfg:24
#, kde-format
msgid "Path to base directory"
msgstr "Cesta k základnému priečinku"

#: setupwizard.cpp:28
#, kde-format
msgctxt "@title:window"
msgid "EteSync configuration wizard"
msgstr "Sprievodca nastavením EteSync"

#: setupwizard.cpp:66
#, kde-format
msgid "Login Credentials"
msgstr "Prihlasovacie údaje"

#: setupwizard.cpp:67
#, kde-format
msgid "Enter your credentials to login to the EteSync server"
msgstr "Zadajte svoje prihlasovacie údaje na prihlásenie na server EteSync"

#: setupwizard.cpp:76
#, kde-format
msgid "Username:"
msgstr "Užívateľské meno:"

#: setupwizard.cpp:82
#, kde-format
msgid "Password:"
msgstr "Heslo:"

#: setupwizard.cpp:85
#, kde-format
msgctxt "@option:check"
msgid "Advanced settings"
msgstr "Pokročilé nastavenia"

#: setupwizard.cpp:90
#, kde-format
msgid "Server:"
msgstr "Server:"

#: setupwizard.cpp:103
#, kde-format
msgid ""
"🛈 The password field is empty because EteSync does not store it for security "
"reasons."
msgstr ""
"🛈 Pole s heslom je prázdne, pretože EteSync ho z bezpečnostných dôvodov "
"neukladá."

#: setupwizard.cpp:135
#, kde-format
msgid ""
"Please ensure that the server URL is correct. The URL should start with "
"http:// or https://."
msgstr ""
"Uistite sa, že adresa URL servera je správna. Adresa URL by mala začínať na "
"http:// alebo https://."

#: setupwizard.cpp:137
#, kde-format
msgid ""
"Could not connect to the server. Please ensure that the server URL is "
"correct."
msgstr ""
"Nepodarilo sa pripojiť na server. Uistite sa, že adresa URL servera je "
"správna."

#: setupwizard.cpp:139
#, kde-format
msgid "EteSync server not found. Please ensure that the server URL is correct."
msgstr ""
"Server EteSync sa nenašiel. Uistite sa, že adresa URL servera je správna."


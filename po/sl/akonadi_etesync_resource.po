#: setupwizard.cpp:28
#, kde-format
msgctxt "@title:window"
msgid "EteSync configuration wizard"
msgstr "Nastavitveni čarovnik za EteSync"

#: setupwizard.cpp:66
#, kde-format
msgid "Login Credentials"
msgstr "Poverilnice za prijavo"

#: setupwizard.cpp:67
#, kde-format
msgid "Enter your credentials to login to the EteSync server"
msgstr "Vnesite svoje poverilnice za prijavo na strežnik EteSync"

#: setupwizard.cpp:76
#, kde-format
msgid "Username:"
msgstr "Uporabniško ime:"

#: setupwizard.cpp:82
#, kde-format
msgid "Password:"
msgstr "Geslo:"

#: setupwizard.cpp:85
#, kde-format
msgctxt "@option:check"
msgid "Advanced settings"
msgstr "Napredne nastavitve"

#: setupwizard.cpp:90
#, kde-format
msgid "Server:"
msgstr "Strežnik:"

#: setupwizard.cpp:103
#, kde-format
msgid ""
"🛈 The password field is empty because EteSync does not store it for security "
"reasons."
msgstr ""
"🛈 Geslo je prazno, ker EteSync zaradi varnostnih razlogov ne shranjuje gesel."

#: setupwizard.cpp:135
#, kde-format
msgid ""
"Please ensure that the server URL is correct. The URL should start with "
"http:// or https://."
msgstr ""
"Zagotovite, da je URL strežnika pravilen. URL se mora začeti s http:// ali "
"https://."

#: setupwizard.cpp:137
#, kde-format
msgid ""
"Could not connect to the server. Please ensure that the server URL is "
"correct."
msgstr ""
"Ni bilo mogoče vzpostaviti povezave s strežnikom. Prepričajte se, da je URL "
"strežnika pravilen."

#: setupwizard.cpp:139
#, kde-format
msgid "EteSync server not found. Please ensure that the server URL is correct."
msgstr ""
"Strežnika EteSync ni mogoče najti. Prepričajte se, da je spletni naslov "
"strežnika pravilen."


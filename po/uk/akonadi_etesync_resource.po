#: etesyncresource.cpp:596
#, kde-format
msgid "Could not create new etesyncCollection"
msgstr "Не вдалося створити etesyncCollection"

#: etesyncresource.h:58
#, kde-format
msgid "Something went wrong"
msgstr "Виникли якісь проблеми"

#. i18n: ectx: label, entry (BaseUrl), group (General)
#: etesyncresource.kcfg:14
#, kde-format
msgid "Server URL"
msgstr "Адреса сервера"

#. i18n: ectx: tooltip, entry (BaseUrl), group (General)
#. i18n: ectx: whatsthis, entry (BaseUrl), group (General)
#: etesyncresource.kcfg:15 etesyncresource.kcfg:16
#, kde-format
msgid ""
"The URL of the EteSync server, should be something like https://myserver.org/"
msgstr ""
"Адреса URL сервера EteSync, слід вказувати у форматі https://myserver.org/"

#. i18n: ectx: label, entry (Username), group (General)
#: etesyncresource.kcfg:19
#, kde-format
msgctxt "the username to login on server"
msgid "Username"
msgstr "Користувач"

#. i18n: ectx: tooltip, entry (Username), group (General)
#. i18n: ectx: whatsthis, entry (Username), group (General)
#: etesyncresource.kcfg:20 etesyncresource.kcfg:21
#, kde-format
msgid "The username that is used to log into the EteSync server"
msgstr ""
"Ім'я користувача, яке буде використано для реєстрації на сервері EteSync"

#. i18n: ectx: label, entry (BasePath), group (General)
#: etesyncresource.kcfg:24
#, kde-format
msgid "Path to base directory"
msgstr "Шлях до базового каталогу"

#: setupwizard.cpp:28
#, kde-format
msgctxt "@title:window"
msgid "EteSync configuration wizard"
msgstr "Майстер налаштовування EteSync"

#: setupwizard.cpp:66
#, kde-format
msgid "Login Credentials"
msgstr "Реєстраційні дані"

#: setupwizard.cpp:67
#, kde-format
msgid "Enter your credentials to login to the EteSync server"
msgstr "Введіть ваші реєстраційні дані на сервері EteSync"

#: setupwizard.cpp:76
#, kde-format
msgid "Username:"
msgstr "Користувач:"

#: setupwizard.cpp:82
#, kde-format
msgid "Password:"
msgstr "Пароль:"

#: setupwizard.cpp:85
#, kde-format
msgctxt "@option:check"
msgid "Advanced settings"
msgstr "Додаткові параметри"

#: setupwizard.cpp:90
#, kde-format
msgid "Server:"
msgstr "Сервер:"

#: setupwizard.cpp:103
#, kde-format
msgid ""
"🛈 The password field is empty because EteSync does not store it for security "
"reasons."
msgstr ""
"🛈 Поле пароля є порожнім, оскільки EteSync не зберігає дані щодо введених "
"паролів з міркувань безпеки."

#: setupwizard.cpp:135
#, kde-format
msgid ""
"Please ensure that the server URL is correct. The URL should start with "
"http:// or https://."
msgstr ""
"Будь ласка, переконайтеся, що правильно вказано адресу сервера. Адреса має "
"починатися з http:// або https://."

#: setupwizard.cpp:137
#, kde-format
msgid ""
"Could not connect to the server. Please ensure that the server URL is "
"correct."
msgstr ""
"Не вдалося встановити з'єднання з сервером. Будь ласка, переконайтеся, що "
"адресу сервера вказано правильно."

#: setupwizard.cpp:139
#, kde-format
msgid "EteSync server not found. Please ensure that the server URL is correct."
msgstr ""
"Не знайдено сервера EteSync. Будь ласка, переконайтеся, що адресу сервера "
"вказано правильно."


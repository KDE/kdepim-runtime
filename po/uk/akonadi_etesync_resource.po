msgstr "Не вдалося отримати etesyncCollection з кешу «%1»"

#: etesyncresource.cpp:424
#, kde-format
msgid "Could not create new etesyncItem '%1'"
msgstr "Не вдалося створити etesyncItem «%1»"

#: etesyncresource.cpp:476 etesyncresource.cpp:534
#, kde-format
msgid "Could not get etesyncItem from cache '%1'"

msgstr "No s'ha pogut crear l'«etesyncItem» «%1» nou"

#: etesyncresource.cpp:476 etesyncresource.cpp:534
#, kde-format
msgid "Could not get etesyncItem from cache '%1'"
msgstr "No s'ha pogut obtenir «etesyncItem» de la memòria cau «%1»"

#: etesyncresource.cpp:596
#, kde-format
msgid "Could not create new etesyncCollection"
msgstr "No s'ha pogut crear un «etesyncCollection» nou"

#: etesyncresource.h:58

#: etesyncresource.cpp:187
#, kde-format
msgid "Server error"
msgstr "Error del servidor"

#: etesyncresource.cpp:206
#, kde-format
msgid ""
"Your EteSync credentials were changed. Please click OK to re-enter your "
"credentials."
msgstr ""
"S'han canviat les vostres credencials d'EteSync. Feu clic a D'acord per a "
"tornar a introduir les credencials."

#: etesyncresource.cpp:208
#, kde-format
msgid "Credentials Changed"
msgstr "S'han canviat les credencials"

#: etesyncresource.cpp:209
#, kde-format
msgid "Your EteSync credentials were changed or are missing."
msgstr "Manquen o s'han canviat les vostres credencials d'EteSync."

#: etesyncresource.cpp:259
#, kde-format
msgid "Cannot retrieve items - account is null"
msgstr "No s'han pogut els elements - el compte és nul"


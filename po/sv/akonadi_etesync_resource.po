#: setupwizard.cpp:28
#, kde-format
msgctxt "@title:window"
msgid "EteSync configuration wizard"
msgstr "EteSync inställningsguide"

#: setupwizard.cpp:66
#, kde-format
msgid "Login Credentials"
msgstr "Inloggningsinformation"

#: setupwizard.cpp:67
#, kde-format
msgid "Enter your credentials to login to the EteSync server"
msgstr "Ange din behörighetsinformation för att logga in på EteSync-servern"

#: setupwizard.cpp:76
#, kde-format
msgid "Username:"
msgstr "Användarnamn:"

#: setupwizard.cpp:82
#, kde-format
msgid "Password:"
msgstr "Lösenord:"

#: setupwizard.cpp:85
#, kde-format
msgctxt "@option:check"
msgid "Advanced settings"
msgstr "Avancerade inställningar"

#: setupwizard.cpp:90
#, kde-format
msgid "Server:"
msgstr "Server:"

#: setupwizard.cpp:103
#, kde-format
msgid ""
"🛈 The password field is empty because EteSync does not store it for security "
"reasons."
msgstr ""
"🛈 Lösenordsfältet är tomt eftersom EteSync inte lagrar det av säkerhetsskäl."

#: setupwizard.cpp:135
#, kde-format
msgid ""
"Please ensure that the server URL is correct. The URL should start with "
"http:// or https://."
msgstr ""
"Säkerställ att serverns webbadress är korrekt. Webbadressen måste börja med "
"http:// eller https://."

#: setupwizard.cpp:137
#, kde-format
msgid ""
"Could not connect to the server. Please ensure that the server URL is "
"correct."
msgstr ""
"Kunde inte ansluta till servern. Säkerställ att serverns webbadress är "
"korrekt."

#: setupwizard.cpp:139
#, kde-format
msgid "EteSync server not found. Please ensure that the server URL is correct."
msgstr ""
"EteSync-servern hittades inte. Säkerställ att serverns webbadress är korrekt."

